{
  "name": "@splaro/admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node ../../scripts/ensure-next-cache.mjs apps/admin && node ../../scripts/verify-css.mjs && node ../../scripts/check-api-up.mjs",
    "prebuild": "node ../../scripts/verify-css.mjs",
    "dev": "next dev --port 3001",
    "dev:fresh": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && next dev --port 3001",
    "css:fix": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && echo 'Admin CSS cache cleared — run pnpm dev:admin'",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@splaro/types": "workspace:*",
    "@splaro/config": "workspace:*",
    "next": "15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^11.3.0",
    "zustand": "^4.5.4",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "react-hook-form": "^7.52.1",
    "zod": "^3.23.8",
    "@hookform/resolvers": "^3.9.0",
    "recharts": "^2.12.7",
    "lucide-react": "^0.400.0",
    "date-fns": "^3.6.0",
    "react-hot-toast": "^2.4.1",
    "cmdk": "^1.0.0",
    "@tanstack/react-table": "^8.19.3",
    "@tanstack/react-query": "^5.51.1",
    "react-dropzone": "^14.2.3",
    "next-themes": "^0.3.0",
    "react-beautiful-dnd": "^13.1.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^20.14.9",
    "@types/react-beautiful-dnd": "^13.1.8",
    "typescript": "^5.5.3",
    "tailwindcss": "^3.4.6",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.0.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5"
  }
}
