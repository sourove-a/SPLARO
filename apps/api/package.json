{
  "name": "@splaro/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node ../../scripts/api-preflight.mjs",
    "preflight": "node ../../scripts/api-preflight.mjs",
    "dev": "node ../../scripts/api-dev.mjs",
    "dev:tsx": "echo 'dev:tsx breaks NestJS DI — use pnpm dev (ts-node-dev)' && exit 1",
    "build": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); try{fs.unlinkSync('tsconfig.build.tsbuildinfo')}catch(e){}\" && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "check": "tsc -p tsconfig.build.json --noEmit",
    "lint": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.16.0",
    "@splaro/config": "workspace:*",
    "@splaro/database": "workspace:*",
    "@splaro/types": "workspace:*",
    "axios": "^1.7.2",
    "bullmq": "^5.25.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsbarcode": "^3.11.6",
    "meilisearch": "^0.41.0",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^9.0.1",
    "puppeteer": "^24.2.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/nodemailer": "^8.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3"
  }
}
