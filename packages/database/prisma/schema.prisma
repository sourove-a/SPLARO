// ============================================================
// SPLARO — Prisma Database Schema v2 (Enterprise)
// PostgreSQL 16 | Prisma 5.x
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

