# ═══════════════════════════════════════════════════════════════════
# SPLARO — Hostinger production environment template
# ═══════════════════════════════════════════════════════════════════
# Copy values into hPanel → your domain → Deployments → Environment
# variables (or ~/.env on the host). NEVER commit a real .env file.
#
# Required values have no default here on purpose — the build fails
# fast via scripts/validate-production-env.mjs if any is missing or
# still a placeholder.
# ═══════════════════════════════════════════════════════════════════

NODE_ENV=production
SPLARO_HOSTINGER=1

# ── Public URLs (REQUIRED) ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://splaro.co
NEXT_PUBLIC_ADMIN_URL=https://admin.splaro.co
# API served through the web domain proxy (recommended on Hostinger):
NEXT_PUBLIC_API_URL=https://splaro.co/api/v1
WEB_URL=https://splaro.co
ADMIN_URL=https://admin.splaro.co
API_URL=https://splaro.co/api/v1
CORS_ORIGINS=https://splaro.co,https://www.splaro.co,https://admin.splaro.co

# ── Database (REQUIRED) ──────────────────────────────────────────────
# Use an EXTERNAL managed PostgreSQL (Neon / Supabase free tier works).
# Shared hosting local PostgreSQL is fragile — see HOSTINGER_DEPLOY.md.
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=
# Optional — only needed if you run `prisma migrate dev` against prod (don't):
# DATABASE_URL_SHADOW=

# ── Secrets (REQUIRED — generate fresh, min 32 chars each) ───────────
# Generate each with:  openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=
ADMIN_SESSION_SECRET=
ENCRYPTION_KEY=
REVALIDATE_SECRET=
INTERNAL_HEALTH_SECRET=

# ── Admin identity (REQUIRED) ────────────────────────────────────────
ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_STORE_ID=splaro

# ── Production safety flags (REQUIRED — never true in production) ────
PAYMENT_DEV_STUB=false
COURIER_DEV_STUB=false

# ── Redis (optional — Hostinger shared has no Redis; leave disabled) ─
REDIS_ENABLED=false
# REDIS_URL=

# ── Telegram (optional but strongly recommended — owner ops channel) ─
# Without these: no order alerts, no admin login-token delivery.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_USER_ID=
# TELEGRAM_STORE_SLUG=splaro

# ── SMTP email (optional) ────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="SPLARO <no-reply@splaro.co>"

# ── Cloudflare R2 media storage (optional) ───────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# NEXT_PUBLIC_CDN_URL=

# ── Courier integrations (optional — real keys only, no placeholders) ─
# STEADFAST_API_KEY=
# STEADFAST_SECRET_KEY=
# PATHAO_CLIENT_ID=
# PATHAO_CLIENT_SECRET=

# ── Payment gateways (optional — real credentials only) ──────────────
# BKASH_APP_KEY=
# BKASH_APP_SECRET=
# BKASH_USERNAME=
# BKASH_PASSWORD=
# SSLCOMMERZ_STORE_ID=
# SSLCOMMERZ_STORE_PASSWORD=

# ── Build-time toggles (defaults are correct; override rarely) ───────
SPLARO_BUILD_ADMIN=1
SPLARO_BUILD_API=1
# Run DB seed on next build (one-time bootstrap only):
# SPLARO_RUN_SEED=1
# Allow prisma db push data loss (NEVER unless you know exactly why):
# SPLARO_DB_PUSH_ACCEPT_DATA_LOSS=1
