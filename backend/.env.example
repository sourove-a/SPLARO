# ---------------------------------------------------------
# SPLARO BACKEND CONFIGURATION (.env)
# ---------------------------------------------------------

PORT=4000
NODE_ENV=production
FRONTEND_URL=https://splaro.co

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://splaro_admin:splaro_secret_password@localhost:5432/splaro_production?schema=public"

# --- Authentication (JWT) ---
JWT_SECRET="splaro_ultra_secure_master_jwt_key_2026"
JWT_REFRESH_SECRET="splaro_refresh_token_vault_key"

# --- Redis (Queue & Caching) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- AI Intelligence Providers ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxx

# --- Payment Gateways ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
SSL_STORE_ID=xxxxxxxxxxxxxxxx
SSL_STORE_PASSWORD=xxxxxxxxxxxxxxxx

# --- Search & SEO ---
MEILI_MASTER_KEY=splaro_master_search_key
MEILI_HOST=http://localhost:7700

# --- Cloud Storage (S3) ---
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
AWS_S3_BUCKET=splaro-assets-production

# --- Shipping & Courier ---
PATHAO_CLIENT_ID=xxxxxxxxxxxx
PATHAO_CLIENT_SECRET=xxxxxxxxxxxx
