{
  "name": "splaro-brand",
  "version": "1.0.0",
  "private": true,
  "description": "SPLARO — Luxury Women's Fashion eCommerce Platform",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:stack": "node scripts/dev-stack.mjs",
    "dev:reset": "node scripts/dev-reset.mjs",
    "dev:web": "turbo run dev --filter=@splaro/web",
    "dev:admin": "turbo run dev --filter=@splaro/admin",
    "dev:api": "turbo run dev --filter=@splaro/api",
    "build": "node scripts/build.mjs",
    "build:web": "turbo run build --filter=@splaro/web",
    "build:admin": "turbo run build --filter=@splaro/admin",
    "build:api": "turbo run build --filter=@splaro/api",
    "build:all": "turbo run build",
    "start": "node scripts/start.mjs",
    "start:web": "turbo run start --filter=@splaro/web",
    "start:admin": "turbo run start --filter=@splaro/admin",
    "start:api": "turbo run start --filter=@splaro/api",
    "start:all": "pm2 start infrastructure/pm2/ecosystem.config.js",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "bash -lc 'set -a && source .env && set +a && cd packages/database && npx prisma generate'",
    "db:migrate": "bash -lc 'set -a && source .env && set +a && cd packages/database && npx prisma migrate dev'",
    "db:migrate:prod": "bash -lc 'set -a && source .env && set +a && cd packages/database && npx prisma migrate deploy'",
    "db:push": "bash -lc 'set -a && source .env && set +a && cd packages/database && npx prisma db push'",
    "db:push:prod": "bash -lc 'set -a && source .env && set +a && cd packages/database && npx prisma db push --accept-data-loss'",
    "db:seed": "bash -lc 'set -a && source .env && set +a && cd packages/database && npx prisma db seed'",
    "db:seed:categories": "bash -lc 'set -a && source .env && set +a && cd apps/api && npx ts-node --transpile-only scripts/seed-category-tree.ts'",
    "telegram:configure": "bash -lc 'set -a && source .env && set +a && cd packages/database && npx tsx prisma/configure-telegram.ts'",
    "db:studio": "cd packages/database && npx prisma studio",
    "db:reset": "cd packages/database && npx prisma migrate reset",
    "db:backup": "bash infrastructure/scripts/backup-db.sh",
    "infra:up": "docker compose up -d postgres redis",
    "infra:redis": "brew services start redis 2>/dev/null || docker compose up -d redis",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis",
    "sheets:sync": "cd tools/google-sheets-sync && pnpm sync:all",
    "print:start": "cd tools/print-service && pnpm build && pnpm start",
    "invoice:test": "cd tools/invoice-generator && pnpm build && pnpm test",
    "deploy": "bash infrastructure/scripts/deploy.sh",
    "deploy:hostinger": "bash infrastructure/hostinger/push-deploy.sh",
    "deploy:hostinger:fresh": "bash infrastructure/hostinger/push-deploy.sh -- -m \"deploy: splaro.co fresh\" && bash infrastructure/hostinger/run-fresh-deploy.sh",
    "deploy:hostinger:ssh": "bash infrastructure/hostinger/run-from-mac.sh",
    "prep:vps": "bash infrastructure/vps/prep-from-mac.sh",
    "prep:vps:build": "bash infrastructure/vps/prep-from-mac.sh --build",
    "deploy:vps": "bash infrastructure/vps/prep-from-mac.sh --deploy",
    "deploy:vps:remote": "pnpm push:safe",
    "setup:vps:github": "bash infrastructure/vps/setup-github-deploy.sh",
    "setup:server": "bash infrastructure/scripts/setup-server.sh",
    "install:vps": "bash infrastructure/vps/install-stack.sh",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "check": "turbo run check",
    "check:web": "turbo run check --filter=@splaro/web",
    "check:admin": "turbo run check --filter=@splaro/admin",
    "check:api": "turbo run check --filter=@splaro/api",
    "typecheck": "turbo run type-check",
    "doctor": "node scripts/doctor.mjs",
    "verify:css": "node scripts/verify-css.mjs",
    "css:health": "node scripts/css-health.mjs",
    "css:fix": "rm -rf apps/web/.next apps/admin/.next apps/web/tsconfig.tsbuildinfo apps/admin/tsconfig.tsbuildinfo && echo 'Next cache cleared — restart pnpm dev:stack'",
    "css:fix:web": "pnpm --filter @splaro/web css:fix",
    "css:fix:admin": "pnpm --filter @splaro/admin css:fix",
    "icons:generate": "node scripts/generate-splaro-icons.mjs",
    "preflight:api": "node scripts/api-preflight.mjs",
    "verify:production": "node scripts/verify-production.mjs",
    "validate:production-env": "node scripts/validate-production-env.mjs",
    "ci:verify": "node scripts/ci-verify.mjs",
    "predeploy": "node scripts/pre-deploy.mjs",
    "prepush": "node scripts/pre-push.mjs",
    "push:safe": "pnpm ci:verify && git push origin main",
    "deploy:hostinger:safe": "pnpm predeploy && bash infrastructure/hostinger/push-deploy.sh",
    "setup:hooks": "node scripts/setup-git-hooks.mjs",
    "verify:deploy-health": "node scripts/verify-deploy-health.mjs",
    "build:hostinger": "bash scripts/hostinger-build.sh",
    "start:hostinger": "node apps/web/.next/standalone/apps/web/server.js",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0+sha512.f549b8a52c9d2b8536762f99c0722205efc5af913e77835dbccc3b0b0b2ca9e7dc8022b78062c17291c48e88749c70ce88eb5a74f1fa8c4bf5e18bb46c8bd83a"
}
