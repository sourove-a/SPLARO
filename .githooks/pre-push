#!/bin/sh
# SPLARO — block push when type-check or web lint would fail CI
# Cross-platform: Git for Windows ships sh.exe; macOS/Linux use /bin/sh.
# Resolve repo root without relying on bash-only features.
HOOK_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
ROOT=$(CDPATH= cd -- "$HOOK_DIR/.." && pwd)
exec node "$ROOT/scripts/pre-push.mjs"
