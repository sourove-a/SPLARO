# ============================================================
# SPLARO — Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control
# ============================================================

# ── APP ─────────────────────────────────────────────────────
# Local dev: use http://localhost:3000 / :3001 / :4000 (see pnpm dev:stack)
# Production (Hostinger VPS): splaro.co / admin.splaro.co / api.splaro.co
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://splaro.com.bd
# Set to true to show maintenance page site-wide (preview at /maintenance anytime)
NEXT_PUBLIC_MAINTENANCE_MODE=false
# ISO date when maintenance ends — used for countdown (Bangladesh time +06:00)
NEXT_PUBLIC_MAINTENANCE_UNTIL=2026-07-01T00:00:00+06:00
NEXT_PUBLIC_API_URL=https://api.splaro.com.bd/api/v1
NEXT_PUBLIC_CDN_URL=https://cdn.splaro.com.bd
NEXT_PUBLIC_ADMIN_URL=https://admin.splaro.com.bd
WEB_URL=https://splaro.com.bd
ADMIN_URL=https://admin.splaro.com.bd
API_URL=https://api.splaro.com.bd
PORT_WEB=3000
PORT_ADMIN=3001
PORT_API=4000
API_PORT=4000

# ── ADMIN PANEL AUTH ─────────────────────────────────────────
# Must match CEO_EMAIL in apps/admin/src/lib/auth/role-label.ts
ADMIN_EMAIL=splaro.bd@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=splaro.bd@gmail.com
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=splaro_bot
ADMIN_PASSWORD=Splaro@2026!
ADMIN_SESSION_SECRET=your-admin-session-secret-min-32-chars
JWT_SECRET=your-super-secret-256-bit-key-change-in-production
REVALIDATE_SECRET=your-revalidate-secret-min-16-chars
INTERNAL_HEALTH_SECRET=your-internal-health-probe-secret
ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-long
NEXT_PUBLIC_STORE_ID=splaro

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://splaro_user:STRONG_PASSWORD@localhost:5432/splaro_db
DATABASE_URL_SHADOW=postgresql://splaro_user:STRONG_PASSWORD@localhost:5432/splaro_shadow_db

# Local dev without Docker: brew install redis && brew services start redis
# With Docker: pnpm infra:up
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DB=0
REDIS_ENABLED=true

# ── RATE LIMITING & THROTTLE ─────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=200

# Production DATABASE_URL tip: add ?connection_limit=20&pool_timeout=20

# ── JWT AUTH ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-256-bit-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-different-from-above
JWT_REFRESH_EXPIRES_IN=30d

# ── NEXT AUTH (if using Auth.js) ──────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-key
NEXTAUTH_URL=https://splaro.com.bd

# ── BKASH PAYMENT ────────────────────────────────────────────
# PAYMENT_DEV_STUB=true allows bKash/Nagad checkout flow in dev without merchant credentials
PAYMENT_DEV_STUB=true
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password
BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta
# For sandbox: https://tokenized.sandbox.bka.sh/v1.2.0-beta

# ── NAGAD PAYMENT ────────────────────────────────────────────
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_MERCHANT_PRIVATE_KEY=your-nagad-private-key
NAGAD_MERCHANT_PUBLIC_KEY=nagad-provided-public-key
NAGAD_BASE_URL=https://api.mynagad.com
# For sandbox: http://sandbox.mynagad.com:10080

# ── SSLCOMMERZ PAYMENT ───────────────────────────────────────
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sslcommerz-store-password
SSLCOMMERZ_BASE_URL=https://securepay.sslcommerz.com
# For sandbox: https://sandbox.sslcommerz.com

# ── STEADFAST COURIER ────────────────────────────────────────
STEADFAST_API_KEY=your-steadfast-api-key
STEADFAST_SECRET_KEY=your-steadfast-secret-key
STEADFAST_BASE_URL=https://portal.steadfast.com.bd/public/api/v1
# Auto-book Steadfast on new order (via API). Set false to disable.
AUTO_COURIER_BOOK=true
DEFAULT_COURIER_PROVIDER=STEADFAST
# Simulate Steadfast booking locally when API keys are placeholders
COURIER_DEV_STUB=false

# ── PATHAO COURIER ───────────────────────────────────────────
PATHAO_CLIENT_ID=your-pathao-client-id
PATHAO_CLIENT_SECRET=your-pathao-client-secret
PATHAO_USERNAME=your-pathao-username
PATHAO_PASSWORD=your-pathao-password
PATHAO_BASE_URL=https://merchant.pathao.com/api/v1
# For sandbox: https://hermes.p-stageenv.xyz/aladdin/api/v1

# ── REDX COURIER ─────────────────────────────────────────────
REDX_API_KEY=your-redx-api-key
REDX_BASE_URL=https://openapi.redx.com.bd/v1.0.0-beta

# ── PAPERFLY COURIER ─────────────────────────────────────────
PAPERFLY_API_USER=your-paperfly-api-user
PAPERFLY_API_PASSWORD=your-paperfly-api-password
PAPERFLY_BASE_URL=https://mrx.paperfly.com.bd/api

# ── CLOUDFLARE R2 STORAGE ────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=your-r2-access-key
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET=splaro-assets
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.splaro.com.bd

# ── OPENAI (AI FEATURES) ─────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_MINI=gpt-4o-mini

# ── ANTHROPIC CLAUDE (SPLARO AI AGENT) ───────────────────────
# Option A: Direct API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Option B: Antigravity proxy (Google login via local proxy, like Claude Code)
# Run: npx antigravity-claude-proxy  →  add Google account at http://localhost:8080
ANTHROPIC_BASE_URL=http://localhost:8080
ANTHROPIC_AUTH_TOKEN=test

# ── GOOGLE GEMINI (SPLARO AI AGENT) ──────────────────────────
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ── XAI GROK (SPLARO AI AGENT) ───────────────────────────────
# Get key: https://console.x.ai
GROK_API_KEY=your-grok-api-key
GROK_MODEL=grok-beta

# ── EMAIL (SMTP) ─────────────────────────────────────────────
SMTP_HOST=mail.splaro.com.bd
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@splaro.com.bd
SMTP_PASS=your-email-password
EMAIL_FROM_NAME=SPLARO
EMAIL_FROM_ADDRESS=noreply@splaro.com.bd

# ── SMS (Bangladesh) ─────────────────────────────────────────
SMS_PROVIDER=ssl_wireless
# Options: ssl_wireless | alpha_sms | twilio
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SENDER_ID=SPLARO

# ── WHATSAPP BUSINESS ────────────────────────────────────────
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
# WhatsApp contact number for customer chat:
NEXT_PUBLIC_WHATSAPP_NUMBER=+8801XXXXXXXXX

# ── TELEGRAM BOT (order alerts + admin commands) ─────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Optional — only if using webhook mode instead of polling
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret
# Numeric Telegram user ID for bot permissions (your personal ID, not group)
TELEGRAM_ADMIN_USER_ID=your-telegram-user-id
# Bot username for admin login page (without @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=splaro_bot
TELEGRAM_STORE_SLUG=splaro
# Customer support link on storefront (username, not bot token):
NEXT_PUBLIC_TELEGRAM_USERNAME=splaro_support

# ── GOOGLE SHEETS SYNC ───────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_ENABLED=true
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./tools/google-sheets-sync/credentials/service-account.json
GOOGLE_DEFAULT_SPREADSHEET_ID=your-default-spreadsheet-id
# Gmail OAuth (admin → Google Workspace → Connect Gmail)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/admin/google/callback
GOOGLE_OAUTH_LOGIN_HINT=splaro.bd@gmail.com
GOOGLE_SHEETS_ORDERS_ID=your-google-sheet-id-for-orders
GOOGLE_SHEETS_INVENTORY_ID=your-google-sheet-id-for-inventory
GOOGLE_SHEETS_CUSTOMERS_ID=your-google-sheet-id-for-customers
GOOGLE_SHEETS_PRODUCTS_ID=your-google-sheet-id-for-products
GOOGLE_SHEETS_PARTNERS_ID=your-google-sheet-id-for-partner-accounts
GOOGLE_SHEETS_EXPENSES_ID=your-google-sheet-id-for-expenses
GOOGLE_SHEETS_PROFIT_LOSS_ID=your-google-sheet-id-for-profit-loss
GOOGLE_SHEETS_COURIER_ID=your-google-sheet-id-for-courier
GOOGLE_SHEETS_PAYMENT_ID=your-google-sheet-id-for-payment
GOOGLE_SHEETS_DAILY_SUMMARY_ID=your-google-sheet-id-for-daily-summary
GOOGLE_SHEETS_TELEGRAM_LOGS_ID=your-google-sheet-id-for-telegram-logs
GOOGLE_SHEETS_AI_JOBS_ID=your-google-sheet-id-for-ai-jobs
GOOGLE_SHEETS_REVENUE_ID=your-google-sheet-id-for-revenue
GOOGLE_SHEETS_SYNC_INTERVAL=*/5 * * * *

# ── PRINT SERVICE ────────────────────────────────────────────
PRINT_SERVICE_ENABLED=true
PRINT_SERVICE_URL=http://localhost:5000
THERMAL_PRINTER_HOST=192.168.1.100
THERMAL_PRINTER_PORT=9100
THERMAL_PRINTER_TYPE=EPSON
# Options: EPSON | STAR | CITIZEN | CUSTOM
PRINT_AUTO_INVOICE=true
PRINT_AUTO_LABEL=true
NETWORK_PRINTER_URL=ipp://192.168.1.101/printers/splaro-invoice

# ── INVOICE ──────────────────────────────────────────────────
INVOICE_PREFIX=SPL
INVOICE_STARTING_NUMBER=1000
COMPANY_NAME=SPLARO
COMPANY_ADDRESS=House 12, Road 5, Dhanmondi, Dhaka 1205
COMPANY_PHONE=+880 1700-000000
COMPANY_EMAIL=info@splaro.com.bd
COMPANY_WEBSITE=https://splaro.com.bd

# ── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── SECURITY ─────────────────────────────────────────────────
CORS_ORIGINS=https://splaro.com.bd,https://admin.splaro.com.bd
CORS_ORIGIN=https://splaro.com.bd,https://admin.splaro.com.bd
ENCRYPTION_KEY=32-character-encryption-key-here
WEBHOOK_SECRET=your-webhook-signing-secret

# ── FEATURE FLAGS ────────────────────────────────────────────
FEATURE_AI_ENABLED=true
FEATURE_SAAS_ENABLED=false
FEATURE_VENDOR_ENABLED=false
FEATURE_LOYALTY_ENABLED=false
FEATURE_CHATBOT_ENABLED=true
FEATURE_GOOGLE_SHEETS=true
FEATURE_PRINT_AUTO=true
# Phone OTP on track-order — false = phone only, no SMS cost
STOREFRONT_PHONE_OTP_ENABLED=false
NEXT_PUBLIC_STOREFRONT_PHONE_OTP_ENABLED=false

# ── ANALYTICS ────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXXX
FB_PIXEL_ID=XXXXXXXXXXXXXXXX
FB_CAPI_ACCESS_TOKEN=your-meta-conversions-api-access-token
META_MARKETING_ACCESS_TOKEN=your-meta-marketing-api-access-token
META_APP_ID=your-meta-app-id
NEXT_PUBLIC_HOTJAR_ID=XXXXXXX

# ── CRON SCHEDULES (cron syntax) ────────────────────────────
CRON_DAILY_REPORT=0 7 * * *
CRON_STOCK_PREDICTION=0 8 * * 0
CRON_SHEETS_SYNC=*/5 * * * *
CRON_ABANDONED_CART=0 */2 * * *
CRON_DB_BACKUP=0 2 * * *
